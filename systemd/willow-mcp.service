[Unit]
Description=Willow SAP MCP Server — HTTP (SSE) transport for IDE clients
Documentation=https://github.com/rudi193-cmd/willow-2.0
After=network.target postgresql.service

[Service]
Type=simple
Environment=WILLOW_ROOT=%h/github/willow-2.0
Environment=WILLOW_PG_DB=willow_20
Environment=WILLOW_PG_USER=%u
Environment=PYTHONPATH=%h/github/willow-2.0
ExecStart=%h/github/willow-2.0/sap/willow_mcp.sh --http
WorkingDirectory=%h/github/willow-2.0
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
