[Unit]
Description=Willow Metabolic Service — Norn Scheduler
Documentation=https://github.com/rudi193-cmd/willow-1.9
Requires=willow-metabolic.socket

[Service]
Type=simple
Environment=WILLOW_ROOT=%h/willow-1.9
Environment=WILLOW_STORE_ROOT=%h/.willow/store
Environment=WILLOW_PG_DB=willow_20
ExecStart=/bin/sh -c 'python3 "$WILLOW_ROOT/core/metabolic.py"'
StandardInput=socket
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
