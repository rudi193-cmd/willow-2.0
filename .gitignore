__pycache__/
*.pyc
*.pyo
.env
*.egg-info/
dist/
build/
.pytest_cache/
.pytest_results.json
pytest_output.txt
mypy_output.txt
.mcp.json
.worktrees/

# Per-agent MCP config may contain operator secrets (generated by install_project)
agents/*/config/mcp.json

# Symlink at repo root from fleet home — canonical lives in willow-config or .willow/generated
/willow.md
willow/fylgja/config/fleet.env
willow/fylgja/config/settings.global.json

# Public fallback materialization (per-clone generated home)
.willow/generated/

# .willow/ runtime artifacts — config (mcp.json) is tracked, these are not
.willow/store/
.willow/*.db
.willow/vault.db
.willow/*.log
.willow/*-watch-state.json
.willow/.boot-complete
.willow/active-agent
.willow/provenance-scan.json
.willow/fleet_gold_benchmark.json
.mcp.json.bak

# Runtime logs — generated at runtime, not for version control
sap/log/*.jsonl
sap/log/*.md

# Cursor Fylgja hooks — per-machine absolute paths; run install_cursor
.cursor/hooks.json
.cursor/settings.local.json

# Claude Code worktrees
.claude/worktrees/

# RLM chunk state — ephemeral, never commit
.claude/rlm_state/

# Smart home — device credentials and runtime logs (never commit)
apps/smart-home/keys.json
apps/smart-home/devices.json
apps/smart-home/tinytuya.json
apps/smart-home/tuya-raw.json
apps/smart-home/snapshot.json
apps/smart-home/debug.log

# Session handoffs belong in ~/.willow/handoffs/ — not the public repo
docs/handoffs/*
!docs/handoffs/README.md

.claude/scheduled_tasks.lock
.claude/settings.local.json

# Agent KB atom scratch files — ephemeral, ingested into Postgres
agents/hanuman/kb-atoms/

# Python virtual environments
.venv/
.venv-dev/
venv/

# Local overseer run logs (scripts/run_overseer.py)
.overseer/

# Operator-specific Grove personas (keep local)
scripts/sean.md

*.sqlite
*.sqlite3
*.db
sap/tools/handoffs.db
gaps.db
archive/*.db
.willow/secrets.sh

# Kart ephemeral scripts (agent_task_submit script_body)
.kart-scripts/

# Upstream steward clones + local worktrees (gitignored per worktree.md)
worktrees/

# Ephemeral tracker output (update_tracker.py uses tempfile; ignore strays)
issue_body.md

# Generated API reference (scripts/build_api_docs.sh)
docs/api/

# LoCoMo benchmark — run artifacts and downloaded dataset files
willow/bench/locomo/external_runs/
willow/bench/locomo/data/
