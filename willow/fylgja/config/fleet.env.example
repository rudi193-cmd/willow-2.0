# Fleet environment — copy to ~/github/.willow/env (willow-config) and edit paths
WILLOW_ROOT={{HOME}}/github/willow-2.0
WILLOW_HOME={{HOME}}/github/.willow
WILLOW_PG_DB=willow_20
WILLOW_PG_USER={{USER}}
WILLOW_GROVE_ROOT={{HOME}}/github/safe-app-willow-grove
WILLOW_STORE_ROOT={{HOME}}/github/.willow/store
WILLOW_SAFE_ROOT={{HOME}}/github/SAFE/Applications
WILLOW_AGENTS_ROOT={{HOME}}/github/SAFE/Agents

WILLOW_INFERENCE_PROVIDER=auto
WILLOW_EDGE_GROQ_MODEL=llama-3.3-70b-versatile
WILLOW_GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=   # free tier works for infer_chat / llm_edge
# GROQ_API_KEY=     # 70b via llama-3.3-70b-versatile
