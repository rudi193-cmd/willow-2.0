{
  "version": 1,
  "loops": [
    {
      "id": "sentinel-watchdog",
      "status": "active",
      "trigger": {
        "kind": "timer",
        "spec": "OnUnitActiveSec=15min",
        "unit": "sentinel-watchdog.timer",
        "external": true
      },
      "task": {
        "kind": "script",
        "ref": "willow-config/fleet-dispatch/sentinel_watchdog.py",
        "model": null
      },
      "verify": {
        "class": "exitcode",
        "predicate": "watchdog exits 0 and boot-sentinel stale rows are cleared or flagged"
      },
      "attention": "SOIL fleet_dispatch/heartbeat + /tmp/willow-boot-done-*.flag",
      "exit": "one pass per timer tick",
      "on_failure": "open_flag",
      "heartbeat": {
        "watchmen_key": "sentinel_watchdog",
        "interval_sec": 900
      },
      "harness": null
    },
    {
      "id": "upstream-watcher",
      "status": "active",
      "trigger": {
        "kind": "daemon",
        "spec": "Restart=on-failure",
        "unit": "upstream-watcher.service"
      },
      "task": {
        "kind": "script",
        "ref": "agents/hanuman/bin/upstream_watcher.py",
        "model": null
      },
      "verify": {
        "class": "coverage",
        "predicate": "heartbeat fresh and gh_ok true when upstream repos are reachable"
      },
      "attention": "GitHub upstream repos configured for hanuman steward",
      "exit": "runs until service stop",
      "on_failure": "open_flag",
      "heartbeat": {
        "watchmen_key": "upstream_watcher",
        "interval_sec": 900
      },
      "harness": null
    },
    {
      "id": "hook-wiring-audit",
