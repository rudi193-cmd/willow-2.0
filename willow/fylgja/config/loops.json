        "kind": "script",
        "ref": "scripts/hook_wiring_audit.py",
        "model": null
      },
      "verify": {
        "class": "schema",
        "predicate": "/home/sean-campbell/.claude/settings.json carries PreToolUse, SessionStart, Stop hook events"
      },
      "attention": "/home/sean-campbell/.claude/settings.json structural summary only",
      "exit": "one audit pass",
      "on_failure": "open_flag",
      "heartbeat": {
        "watchmen_key": "hook_wiring_audit",
        "interval_sec": 86400
      },
      "harness": null
    },
