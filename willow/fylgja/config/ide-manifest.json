{
  "_comment": "Runtime/config templates rendered by install_project. Agent prose templates live in docs/templates/README.md.",
  "ides": {
    "cursor": {
      "hooks_file": "willow/fylgja/config/cursor-hooks.json",
      "cli_file": "willow/fylgja/config/cursor-cli.json",
      "local_settings": "{{WILLOW_HOME}}/agents/{agent}/settings.local.json",
      "symlinks": {
        ".cursor/hooks.json": "../willow/fylgja/config/cursor-hooks.json",
        ".cursor/cli.json": "../willow/fylgja/config/cursor-cli.json",
        ".cursor/mcp.json": "../agents/{agent}/config/mcp.json",
        ".cursor/settings.local.json": "{{WILLOW_HOME}}/agents/{agent}/settings.local.json"
      }
    },
    "claude": {
      "settings_template": "willow/fylgja/config/claude-settings.json",
      "symlinks": {
        ".claude/settings.json": "../willow/fylgja/config/claude-settings.json"
      },
      "local_settings": "{{WILLOW_HOME}}/agents/{agent}/settings.local.json"
    },
    "codex": {
      "toml_template": "willow/fylgja/config/codex-mcp.toml.template",
      "target": "~/.codex/config.toml"
    }
  },
  "agent_config": "agents/{agent}/config",
  "hook_runner": "willow/fylgja/bin/fylgja-hook",
  "mcp_template": "willow/fylgja/config/mcp.template.json"
}
