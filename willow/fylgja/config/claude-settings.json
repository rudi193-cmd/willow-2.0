{
  "sandbox": {
    "mode": "workspace-write",
    "filesystem": {
      "denyRead": [
        "~/.claude",
        "~/archive/willow-1.9",
        "~/github/safe-app-store"
      ]
    }
  },
  "env": {
    "WILLOW_20_DB": "~/.willow/willow-2.0.db",
    "WILLOW_ROOT": ".",
    "WILLOW_SAFE_ROOT": "~/SAFE/Applications"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob"
    ],
    "defaultMode": "default"
  }
}
