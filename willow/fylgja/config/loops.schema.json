{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "willow/fylgja/config/loops.schema.json",
  "title": "Willow loop registry record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "trigger",
    "task",
    "verify",
    "attention",
    "exit",
    "on_failure",
    "heartbeat"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "retired"
      ]
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "timer",
            "hook",
            "daemon"
          ]
        },
        "spec": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "event": {
          "type": "string"
        },
        "external": {
          "type": "boolean"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "script",
            "shell",
            "harness"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verify": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "predicate"
      ],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "recount",
            "exitcode",
            "schema",
            "coverage",
            "containment"
          ]
        },
        "predicate": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "attention": {
      "type": "string",
      "minLength": 1
    },
    "exit": {
      "type": "string",
      "minLength": 1
    },
    "on_failure": {
      "type": "string",
      "enum": [
        "self_heal",
        "queue_decision",
        "open_flag"
      ]
    },
    "review_queue": {
      "type": "string",
      "enum": [
        "mem_ratify",
        "human_required"
      ]
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "watchmen_key",
        "interval_sec"
      ],
      "properties": {
        "watchmen_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,62}$"
        },
        "interval_sec": {
          "type": "integer",
          "minimum": 60
        }
      }
    },
    "harness": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
