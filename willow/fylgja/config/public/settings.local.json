{
  "env": {
    "WILLOW_AGENT_NAME": "{{AGENT_NAME}}",
    "AGENT_NAME": "{{AGENT_NAME}}"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(*)",
      "Bash(*)",
      "Task(*)",
      "mcp__willow__fleet_restart",
      "mcp__willow__*",
      "mcp__codebase-memory-mcp__*",
      "mcp__claude_ai_Grove__*"
    ],
    "deny": [
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__willow__app_uninstall",
      "mcp__willow__policy_put",
      "mcp__willow__policy_delete",
      "mcp__willow__routine_register"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["willow", "codebase-memory-mcp"]
}
