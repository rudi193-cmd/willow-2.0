# Public fallback fleet env — materialized to {{WILLOW_HOME}}/env
# No secrets. Edit paths after clone if your layout differs.

WILLOW_ROOT={{REPO_ROOT}}
WILLOW_HOME={{WILLOW_HOME}}
WILLOW_PG_DB=willow_20
WILLOW_PG_USER={{USER}}
WILLOW_STORE_ROOT={{WILLOW_HOME}}/store
WILLOW_SAFE_ROOT={{HOME}}/github/SAFE/Applications
WILLOW_AGENTS_ROOT={{HOME}}/github/SAFE/Agents
WILLOW_GROVE_ROOT={{HOME}}/github/safe-app-willow-grove

WILLOW_INFERENCE_PROVIDER=auto
WILLOW_EDGE_GROQ_MODEL=llama-3.3-70b-versatile
WILLOW_GEMINI_MODEL=gemini-2.0-flash
# Optional cloud keys — set in your shell, not in this file
# GROQ_API_KEY
# GEMINI_API_KEY
