{
  "mcpServers": {
    "willow": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "sap/unified_mcp.sh"
      ],
      "env": {
        "WILLOW_AGENT_NAME": "willow",
        "GROVE_SENDER": "willow",
        "GROVE_NAME": "willow",
        "WILLOW_ROOT": ".",
        "WILLOW_HOME": ".willow/generated",
        "WILLOW_CONFIG_MODE": "public-fallback",
        "WILLOW_MCP_PROFILE": "standard"
      }
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "codebase-memory-mcp",
      "args": []
    }
  }
}
