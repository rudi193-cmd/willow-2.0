{
  "sandbox": {
    "mode": "workspace-write",
    "filesystem": {
      "denyRead": [
        "/home/example/.claude",
        "/home/example/willow-1.9",
        "/home/example/github/safe-app-store"
      ]
    }
  },
  "env": {
    "WILLOW_20_DB": "/home/example/.willow/willow-2.0.db",
    "WILLOW_ROOT": "/home/example/willow-2.0"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/example/willow-2.0/orchestrator.py"
          },
          {
            "type": "command",
            "command": "python3 /home/example/willow-2.0/persona.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/example/willow-2.0/session_close.py"
          }
        ]
      }
    ]
  }
}
